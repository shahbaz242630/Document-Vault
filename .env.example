# Supabase setup is pending.
# Fill these after the Supabase project is created.
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Supabase SSL pinning (optional, dev builds only).
# Generate base64-encoded SHA-256 SPKI hashes for the Supabase cert chain.
# At least two pins are required per domain on iOS.
EXPO_PUBLIC_SUPABASE_PIN_PRIMARY=
EXPO_PUBLIC_SUPABASE_PIN_BACKUP=

# RevenueCat public SDK keys.
# Use EXPO_PUBLIC_REVENUECAT_API_KEY for a shared/test key, or platform-specific
# keys when separate iOS and Android apps are configured in RevenueCat.
EXPO_PUBLIC_REVENUECAT_API_KEY=
EXPO_PUBLIC_REVENUECAT_IOS_KEY=
EXPO_PUBLIC_REVENUECAT_ANDROID_KEY=

# RevenueCat webhook secret (server-side only, do not prefix with EXPO_PUBLIC).
# Set this in the RevenueCat dashboard under Project Settings → Webhooks.
REVENUECAT_WEBHOOK_SECRET=
