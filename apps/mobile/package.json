{
  "name": "@vault/mobile",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "start:dev-client": "expo start --dev-client",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "test": "vitest run",
    "typecheck": "cross-env EXPO_ROUTER_APP_ROOT=app tsc --noEmit",
    "bundle:analyze": "npx react-native-bundle-visualizer --entry-file node_modules/expo-router/entry"
  },
  "expo": {
    "doctor": {
      "reactNativeDirectoryCheck": {
        "exclude": [
          "react-native-libsodium"
        ]
      }
    },
    "install": {
      "exclude": [
        "@types/react"
      ]
    }
  },
  "dependencies": {
    "@hookform/resolvers": "5.2.2",
    "@supabase/supabase-js": "2.105.4",
    "bip39": "3.1.0",
    "expo": "~54.0.35",
    "expo-build-properties": "1.0.10",
    "expo-constants": "18.0.13",
    "expo-crypto": "~15.0.9",
    "expo-dev-client": "~6.0.21",
    "expo-linking": "8.0.12",
    "expo-local-authentication": "17.0.8",
    "expo-notifications": "0.32.17",
    "expo-router": "~6.0.24",
    "expo-secure-store": "15.0.8",
    "expo-status-bar": "3.0.9",
    "libsodium-wrappers-sumo": "0.7.15",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-hook-form": "7.75.0",
    "react-native": "0.81.5",
    "react-native-libsodium": "^1.7.0",
    "react-native-purchases": "^10.1.1",
    "react-native-purchases-ui": "^10.1.1",
    "react-native-safe-area-context": "5.6.0",
    "react-native-screens": "4.16.0",
    "react-native-ssl-public-key-pinning": "^1.2.6",
    "zod": "4.1.13",
    "zustand": "5.0.13"
  },
  "devDependencies": {
    "@types/react": "19.2.14",
    "@types/react-dom": "~19.1.7",
    "cross-env": "10.1.0",
    "libsodium-wrappers": "0.8.4",
    "react-native-bundle-visualizer": "4.0.0",
    "typescript": "5.9.2",
    "vitest": "4.1.6"
  },
  "private": true
}
