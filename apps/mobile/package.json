{
  "name": "@vault/mobile",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "start:dev-client": "expo start --dev-client",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "doctor": "expo-doctor",
    "typecheck": "cross-env EXPO_ROUTER_APP_ROOT=app tsc --noEmit",
    "bundle:analyze": "npx react-native-bundle-visualizer --entry-file node_modules/expo-router/entry"
  },
  "expo": {
    "doctor": {
      "reactNativeDirectoryCheck": {
        "exclude": [
          "react-native-libsodium"
        ]
      }
    },
    "install": {
      "exclude": [
        "@types/react"
      ]
    }
  },
  "dependencies": {
    "@supabase/supabase-js": "2.108.2",
    "@vault/shared-types": "0.1.0",
    "@vault/shared-validation": "0.1.0",
    "bip39": "3.1.0",
    "buffer": "^5.7.1",
    "expo": "~56.0.12",
    "expo-build-properties": "~56.0.19",
    "expo-constants": "~56.0.18",
    "expo-crypto": "~56.0.4",
    "expo-dev-client": "~56.0.20",
    "expo-linking": "~56.0.14",
    "expo-local-authentication": "~56.0.4",
    "expo-print": "~56.0.4",
    "expo-router": "~56.2.11",
    "expo-screen-capture": "~56.0.4",
    "expo-secure-store": "~56.0.4",
    "expo-sharing": "~56.0.18",
    "expo-splash-screen": "~56.0.10",
    "expo-status-bar": "~56.0.4",
    "libsodium-wrappers-sumo": "0.7.15",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-libsodium": "^1.7.0",
    "react-native-purchases": "^10.4.0",
    "react-native-purchases-ui": "^10.4.0",
    "react-native-safe-area-context": "5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-ssl-public-key-pinning": "^1.2.6",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/react": "19.2.17",
    "@types/react-dom": "~19.2.3",
    "cross-env": "10.1.0",
    "expo-doctor": "1.19.10",
    "libsodium-wrappers": "0.8.4",
    "react-native-bundle-visualizer": "4.0.0",
    "typescript": "^6.0.3",
    "vitest": "4.1.9"
  },
  "private": true
}
