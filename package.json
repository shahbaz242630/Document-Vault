{
  "name": "sanduqkin",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*",
    "services/*"
  ],
  "overrides": {
    "react-devtools-core": {
      "shell-quote": "1.8.4"
    },
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native-safe-area-context": "5.7.0"
  },
  "scripts": {
    "mobile": "npm run start --workspace @vault/mobile",
    "mobile:android": "npm run android --workspace @vault/mobile",
    "mobile:ios": "npm run ios --workspace @vault/mobile",
    "check:phase1": "node scripts/phase1-dod-check.cjs",
    "postinstall": "node scripts/run-patch-package-if-available.cjs",
    "check:github-actions-security": "node scripts/github-actions-security-check.cjs",
    "check:security": "node scripts/security-check.cjs",
    "check:mobile-secrets": "node scripts/mobile-secret-scan.cjs",
    "check:supabase-db-security": "node scripts/supabase-db-security-check.cjs",
    "check:supabase-rls": "node scripts/supabase-rls-attack-test.cjs",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "lint": "eslint . --max-warnings=0"
  },
  "engines": {
    "node": "^22.13.0 || >=24.3.0"
  },
  "devDependencies": {
    "eslint": "9.39.3",
    "eslint-config-expo": "56.0.4",
    "patch-package": "^8.0.1"
  }
}
